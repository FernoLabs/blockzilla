APP_ENV=development
RUST_LOG=shred_reader=info,solana_gossip=warn,solana_streamer=warn

# Production Dokploy pins this to the verified GHCR manifest digest.
SHRED_READER_IMAGE=ghcr.io/fernolabs/blockzilla-shred-reader@sha256:replace-with-published-digest

# Comma-separated gossip entrypoints. The first reachable entrypoint is also
# used to discover this machine's public IP and the cluster shred version.
SOLANA_ENTRYPOINTS=entrypoint.mainnet-beta.solana.com:8001,entrypoint2.mainnet-beta.solana.com:8001,entrypoint3.mainnet-beta.solana.com:8001

IDENTITY_PATH=./data/identity.json
BIND_IP=0.0.0.0
GOSSIP_PORT=18001
TVU_PORT=18002
METRICS_ADDR=127.0.0.1:19090

# Normally auto-discovered through the Solana entrypoint. Set these only when
# discovery is unavailable or when the host has multiple public addresses.
# ADVERTISED_IP=203.0.113.10
# SHRED_VERSION=50093

# Ask an entrypoint to probe all public gossip/TVU ports before startup. Enable
# this on the public test host; it will normally fail on a laptop behind NAT.
REQUIRE_REACHABILITY=false

UDP_RECV_BUFFER_BYTES=67108864
DEDUP_CAPACITY=500000
FORWARD_QUEUE_CAPACITY=16384
METRICS_INTERVAL_SECS=10
SAMPLE_INTERVAL_SECS=15

# Optional comma-separated host interface names. Host-wide UDP/softnet counters
# are always logged; these add NIC-specific receive drop/error counters.
LOSS_TELEMETRY_INTERFACES=eth0

# Repair is disabled for local/NAT runs. Production enables bounded Agave repair
# and writes only validated responses to a separate provenance WAL.
REPAIR_ENABLED=false
REPAIR_RPC_URL=https://api.mainnet-beta.solana.com
REPAIR_WAL_PATH=./data/accepted.repair.wal
REPAIR_WAL_MAX_BYTES=268435456
REPAIR_MAX_PEERS=8
REPAIR_OBSERVATION_QUEUE_CAPACITY=32768

# Comma-separated UDP destinations. Production requires at least one. Every
# structurally valid, same-version shred is forwarded byte-for-byte to each destination.
# SHRED_FORWARD_ADDRS=127.0.0.1:18003

# DOKPLOY_TOKEN is a deployment credential, not an application setting.
# Keep it only in a local or CI secret store; never pass it to this container.
