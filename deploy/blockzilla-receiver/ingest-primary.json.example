      "max_compressed_event_bytes": 134217728,
      "max_uncompressed_event_bytes": 268435456,
      "max_concurrent_requests": 1,
      "max_open_streams": 64,
      "max_known_streams": 4096,
      "tls_handshake_timeout_ms": 10000,
      "request_idle_timeout_ms": 120000,
      "request_total_timeout_ms": 600000
