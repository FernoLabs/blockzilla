  },
  "spool": {
    "root": "/data/blockzilla-ingest-primary",
    "max_bytes": 17592186044416,
    "segment_bytes": 268435456,
    "reserve_free_bytes": 4398046511104,
    "sync": {
      "max_delay_ms": 10,
