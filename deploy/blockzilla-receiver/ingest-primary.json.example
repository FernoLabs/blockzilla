{
  "schema_version": 2,
  "cluster_id": "solana-mainnet",
  "max_total_queue_bytes": 536870912,
  "max_total_queue_events": 16,
  "role": {
    "mode": "primary",
    "node_id": "blockzilla-primary",
    "replica_listener": {
      "bind": "10.253.45.2:9443",
      "server_certificate_file": "/run/secrets/blockzilla_primary_certificate",
      "server_private_key_file": "/tmp/blockzilla-receiver/server-private-key.pem",
      "client_ca_file": "/run/secrets/blockzilla_replica_ca",
      "allowed_nodes_file": "/run/secrets/replication_allowed_nodes",
      "primary_term_file": "/data/replication-control/primary-term",
      "receipt_signing_key_id": "receipt-2026-q3",
      "receipt_signing_key": {
        "provider": "file",
        "path": "/tmp/blockzilla-receiver/receipt-signing-key.pem"
      },
      "max_wire_request_bytes": 134283264,
      "max_batch_events": 4,
      "max_batch_compressed_bytes": 134217728,
