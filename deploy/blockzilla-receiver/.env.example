# This standalone deployment is intentionally inert until explicitly enabled.
COMPOSE_PROJECT_NAME=blockzilla-ingest-receiver
COMPOSE_PROFILES=
BLOCKZILLA_RECEIVER_IMAGE=blockzilla-live-receiver:local
# Keep this distinct from BLOCKZILLA_RECEIVER_IMAGE. Building or updating the
# outbound client must never retag the image backing the live receiver.
BLOCKZILLA_PULL_CLIENT_IMAGE=blockzilla-live-pull-client:local

# Create this dedicated directory on the Blockzilla host as UID/GID 10001 and
# mode 0700. It contains both the durable receiver WAL and the fencing term.
BLOCKZILLA_RECEIVER_DATA_HOST_PATH=/path/to/blockzilla-ingest-receiver

# The bridge writes a separate standard raw-gRPC generation here. Create this
# directory as UID/GID 10001 with mode 0700. The receiver source stays read-only.
BLOCKZILLA_RECEIVER_BRIDGE_OUTPUT_HOST_PATH=/path/to/blockzilla-ingest-receiver-derived
BLOCKZILLA_RECEIVER_BRIDGE_CLUSTER_ID=solana-mainnet
BLOCKZILLA_RECEIVER_BRIDGE_ORIGIN_NODE_ID=hetzner-dokploy-01
BLOCKZILLA_RECEIVER_BRIDGE_SOURCE_ID=grpc-raw-hetzner-backup
# Set only after the receiver creates a journal. It must be exactly 32 hex chars.
BLOCKZILLA_RECEIVER_BRIDGE_JOURNAL_ID=
BLOCKZILLA_RECEIVER_BRIDGE_MAX_RECORDS=128
BLOCKZILLA_RECEIVER_BRIDGE_MAX_UNCOMPRESSED_RECORD_BYTES=134217728
# Stop the derived copy at 8 TiB and preserve 6 TiB of NAS free space. Hitting
# either limit pauses only this copy; it never mutates the canonical receiver.
BLOCKZILLA_RECEIVER_BRIDGE_MAX_OUTPUT_BYTES=8796093022208
BLOCKZILLA_RECEIVER_BRIDGE_MIN_FREE_BYTES=6597069766656
BLOCKZILLA_RECEIVER_BRIDGE_POLL_INTERVAL_SECS=2
BLOCKZILLA_RECEIVER_BRIDGE_FAILURE_RETRY_SECS=60
BLOCKZILLA_RECEIVER_BRIDGE_MEMORY_LIMIT=768m
BLOCKZILLA_RECEIVER_BRIDGE_MEMORY_RESERVATION=128m

# Copy the JSON example before deployment. It is public configuration, but do
# not point Compose at the unedited example.
BLOCKZILLA_RECEIVER_CONFIG_HOST_FILE=/path/to/ingest-primary.json

# PKI files produced by generate-grpc-replication-pki.sh. Private keys must
# remain outside the repository and must never be copied to the other host.
BLOCKZILLA_RECEIVER_CERTIFICATE_HOST_FILE=/path/to/replication-pki/blockzilla/blockzilla-primary.crt
BLOCKZILLA_RECEIVER_PRIVATE_KEY_HOST_FILE=/path/to/replication-pki/blockzilla/blockzilla-primary.key
BLOCKZILLA_RECEIVER_CLIENT_CA_HOST_FILE=/path/to/replication-pki/blockzilla/replica-ca.crt
BLOCKZILLA_RECEIVER_ALLOWLIST_HOST_FILE=/path/to/pull-pki/blockzilla/pull-allowed-nodes.json
BLOCKZILLA_RECEIVER_RECEIPT_KEY_HOST_FILE=/path/to/replication-pki/blockzilla/blockzilla-receipt.key

# Outbound direct pull. These paths are required only when enabling the
# `pull-client` profile. The JSON uses https://188.245.147.127:10443 with TLS
# name `blockzilla-hetzner-source`, and the local sink at
# https://10.253.45.2:9443 with TLS name `blockzilla-primary`.
BLOCKZILLA_PULL_CLIENT_CONFIG_HOST_FILE=/path/to/grpc-pull-client.json
BLOCKZILLA_PULL_CLIENT_CERTIFICATE_HOST_FILE=/path/to/pull-pki/blockzilla/blockzilla-pull-client.crt
BLOCKZILLA_PULL_CLIENT_PRIVATE_KEY_HOST_FILE=/path/to/pull-pki/blockzilla/blockzilla-pull-client.key
BLOCKZILLA_REPLICATION_CA_HOST_FILE=/path/to/pull-pki/blockzilla/hetzner-pull-source-ca.crt
BLOCKZILLA_RECEIPT_PUBLIC_KEY_HOST_FILE=/path/to/pull-pki/blockzilla/blockzilla-receipt.pub
BLOCKZILLA_PULL_CLIENT_POLL_INTERVAL_MS=1000

# Legacy remotely-managed Cloudflare Tunnel token. The connector is now behind
# `legacy-tunnel`; do not stop an already-running instance until the direct
# source -> receiver -> signed-ACK proof succeeds end to end.
BLOCKZILLA_CLOUDFLARED_TOKEN_HOST_FILE=/path/to/cloudflare/blockzilla-receiver-tunnel-token

# Advertise only BLOCKZILLA_RECEIVER_PRIVATE_IP/32 through Cloudflare. These
# addresses exist solely on the dedicated two-container Docker bridge; the
# receiver publishes no NAS host port.
BLOCKZILLA_RECEIVER_INGRESS_NETWORK_NAME=blockzilla-receiver-ingress
BLOCKZILLA_CLOUDFLARED_EGRESS_NETWORK_NAME=blockzilla-cloudflared-egress
BLOCKZILLA_PULL_EGRESS_NETWORK_NAME=blockzilla-pull-egress
BLOCKZILLA_RECEIVER_PRIVATE_SUBNET=10.253.45.0/29
BLOCKZILLA_RECEIVER_PRIVATE_IP=10.253.45.2
BLOCKZILLA_CLOUDFLARED_PRIVATE_IP=10.253.45.3
BLOCKZILLA_RECEIVER_MEMORY_LIMIT=768m
BLOCKZILLA_RECEIVER_MEMORY_RESERVATION=128m
