# Use this with docker-compose.dokploy-pull-source.yml in a NEW Dokploy
# application. Do not reuse the recorder application's Compose project name.
COMPOSE_PROJECT_NAME=blockzilla-grpc-pull-source
# Build this image off-host, preload it on Hetzner, and set the exact content
# address reported by `docker image inspect --format '{{.Id}}'`. A mutable tag
# is deliberately not accepted by this production Compose.
BLOCKZILLA_PULL_SOURCE_IMAGE_ID=sha256:REPLACE_WITH_64_HEX_IMAGE_ID

# The source attaches the existing recorder WAL volume read-only. Its ACK WAL
# and monitoring snapshot live in a separate stable read/write control volume.
# Compose fails if the external recorder volume is absent.
BLOCKZILLA_RAW_VOLUME_NAME=blockzilla-live-raw-data-external
BLOCKZILLA_PULL_CONTROL_VOLUME_NAME=blockzilla-live-pull-control
BLOCKZILLA_PULL_SOURCE_HOST_PORT=10443

# Create these six Dokploy File mounts. Values here are host-side paths only;
# no key, certificate, fingerprint, or receipt material belongs in Environment.
BLOCKZILLA_PULL_SOURCE_CONFIG_HOST_FILE=../files/grpc-pull-source.json
BLOCKZILLA_PULL_SOURCE_CERTIFICATE_HOST_FILE=../files/hetzner-pull-source.crt
BLOCKZILLA_PULL_SOURCE_PRIVATE_KEY_HOST_FILE=../files/hetzner-pull-source.key
BLOCKZILLA_PULL_CLIENT_CA_HOST_FILE=../files/pull-client-ca.crt
BLOCKZILLA_PULL_SOURCE_ALLOWLIST_HOST_FILE=../files/pull-allowed-nodes.json
BLOCKZILLA_RECEIPT_PUBLIC_KEY_HOST_FILE=../files/blockzilla-receipt.pub

# Copy grpc-pull-source.json.example to the Dokploy File mount. Keep its
# max_records=1 and gc.enabled=false during the canary, and make its receipt key
# id match the NAS receiver's configured signing key id.
