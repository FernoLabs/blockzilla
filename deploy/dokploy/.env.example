# Copy these non-secret values into Dokploy's Environment panel.
COMPOSE_PROJECT_NAME=blockzilla-live
BLOCKZILLA_RAW_IMAGE=blockzilla-live-recorder:local

# The endpoint is configuration. The token itself stays in Dokploy's persistent
# application files area and is mounted as a Compose secret.
BLOCKZILLA_GRPC_ENDPOINT=https://yellowstone.example.invalid
BLOCKZILLA_GRPC_X_TOKEN_HOST_FILE=../files/yellowstone-x-token

# Set this before the first start when a replay slot is known. Once the spool has
# a durable row, this bootstrap value is ignored and resume requests that row's
# slot inclusively; the exact prior block is skipped after overlap is observed.
BLOCKZILLA_RAW_FROM_SLOT=

# Persisted identity: never change the endpoint or these values while reusing the
# same cache. Use a new cache for a different source.
BLOCKZILLA_RAW_CLUSTER_ID=solana-mainnet
BLOCKZILLA_RAW_ORIGIN_NODE_ID=hetzner-dokploy-01
BLOCKZILLA_RAW_SOURCE_ID=grpc-raw-hetzner-backup

# The host script provisions an exact 3 GiB filesystem. Generations are capped
# at 384 MiB and become locally deletable only after a verified B2 commit.
BLOCKZILLA_RAW_CACHE_MODE=b2-generations
BLOCKZILLA_RAW_CACHE_ROOT=/data/grpc-cache
BLOCKZILLA_RAW_OUTPUT_DIR=/data/grpc-cache/active
BLOCKZILLA_RAW_MAX_GENERATION_BYTES=402653184
BLOCKZILLA_RAW_SEGMENT_TARGET_BYTES=67108864
BLOCKZILLA_RAW_MAX_RECORD_BYTES=134217728
BLOCKZILLA_RAW_MIN_FREE_BYTES=402653184
BLOCKZILLA_RAW_GENERATION_BACKLOG_WARN_COUNT=2
BLOCKZILLA_RAW_GENERATION_UPLOAD_RETRY_SECS=60
BLOCKZILLA_RAW_CACHE_RECEIPT_DIR=/data/grpc-cache/receipts
BLOCKZILLA_RAW_MEMORY_LIMIT=768m
BLOCKZILLA_RAW_MEMORY_RESERVATION=128m
BLOCKZILLA_RAW_VOLUME_NAME=blockzilla-live-raw-data-external
BLOCKZILLA_RAW_VOLUME_MARKER=/data/.blockzilla-raw-volume
BLOCKZILLA_RAW_REQUIRE_COMPLETE_POH=true
BLOCKZILLA_RAW_IDLE_TIMEOUT_SECS=180

# Backblaze values remain in a root-managed Dokploy file and are parsed as data,
# never sourced by the shell supervisor.
BLOCKZILLA_B2_CREDENTIALS_HOST_FILE=../files/backblaze-blockzilla.env
BLOCKZILLA_B2_REMOTE_PREFIX=grpc-raw/v1

# Telegram alerts are enabled in this deployment. The bot token stays in a
# persistent Compose secret file; the chat/topic identifiers are not secrets.
BLOCKZILLA_TELEGRAM_ENABLED=true
BLOCKZILLA_TELEGRAM_BOT_TOKEN_HOST_FILE=../files/telegram-bot-token
BLOCKZILLA_TELEGRAM_CHAT_ID=
BLOCKZILLA_TELEGRAM_MESSAGE_THREAD_ID=
BLOCKZILLA_TELEGRAM_ALERT_COOLDOWN_SECS=900
BLOCKZILLA_RAW_DISK_WARN_FREE_BYTES=805306368
# Clear disk incidents only after another 128 MiB is available.
BLOCKZILLA_RAW_DISK_RECOVERY_HYSTERESIS_BYTES=134217728
BLOCKZILLA_RAW_MONITOR_INTERVAL_SECS=30

# Disabled until the authenticated primary/replica sync protocol writes a
# heartbeat file into the shared volume. A non-empty path enables this alert.
BLOCKZILLA_PRIMARY_SYNC_HEARTBEAT_FILE=
BLOCKZILLA_PRIMARY_SYNC_STALE_AFTER_SECS=600

# Conservative transport defaults. The server may answer without compression.
BLOCKZILLA_GRPC_ACCEPT_COMPRESSION=zstd
BLOCKZILLA_GRPC_HTTP2_ADAPTIVE_WINDOW=false
BLOCKZILLA_GRPC_HTTP2_KEEP_ALIVE_INTERVAL_SECS=30
BLOCKZILLA_GRPC_HTTP2_KEEP_ALIVE_TIMEOUT_SECS=10
BLOCKZILLA_GRPC_HTTP2_KEEP_ALIVE_WHILE_IDLE=false

# A fresh journal record is expected well inside this window during live ingest.
BLOCKZILLA_RAW_STALE_AFTER_SECS=180
BLOCKZILLA_RAW_STARTUP_GRACE_SECS=300
