# Copy these non-secret values into Dokploy's Environment panel.
COMPOSE_PROJECT_NAME=blockzilla-live
BLOCKZILLA_RAW_IMAGE=blockzilla-live-recorder:local

# The endpoint is configuration. The token itself stays in Dokploy's persistent
# application files area and is mounted as a Compose secret.
BLOCKZILLA_GRPC_ENDPOINT=https://yellowstone.example.invalid
BLOCKZILLA_GRPC_X_TOKEN_HOST_FILE=../files/yellowstone-x-token

# Set this before the first start when a replay slot is known. Once the spool has
# a durable row, this bootstrap value is ignored and resume requests that row's
# slot inclusively; the exact prior block is skipped after overlap is observed.
BLOCKZILLA_RAW_FROM_SLOT=

# Persisted identity: never change the endpoint or these values while reusing the
# same cache. Use a new cache for a different source.
BLOCKZILLA_RAW_CLUSTER_ID=solana-mainnet
BLOCKZILLA_RAW_ORIGIN_NODE_ID=hetzner-dokploy-01
BLOCKZILLA_RAW_SOURCE_ID=grpc-raw-hetzner-primary

# Optional private Yellowstone relay. Leave the bind empty to omit all relay CLI
# flags. To enable it inside the Compose network, set 0.0.0.0:10001 and create a
# dedicated token file; never copy the paid upstream token into this file.
BLOCKZILLA_RAW_RELAY_BIND=
BLOCKZILLA_RAW_RELAY_X_TOKEN_HOST_FILE=../files/yellowstone-relay-x-token
BLOCKZILLA_RAW_RELAY_MAX_RECORDS=128
BLOCKZILLA_RAW_RELAY_MAX_ENCODED_BYTES=134217728
BLOCKZILLA_RAW_RELAY_MAX_CLIENTS=4

# The current host script provisions an exact 3 GiB filesystem. Every block is
# written here first. Generations are capped at 384 MiB and are not locally
# deletable until a verified signed Blockzilla durable-raw ACK exists.
# `b2-generations` remains the compatible cache-mode name when R2 is selected.
BLOCKZILLA_RAW_CACHE_MODE=b2-generations
BLOCKZILLA_RAW_CACHE_ROOT=/data/grpc-cache
BLOCKZILLA_RAW_OUTPUT_DIR=/data/grpc-cache/active
BLOCKZILLA_RAW_MAX_GENERATION_BYTES=402653184
BLOCKZILLA_RAW_SEGMENT_TARGET_BYTES=67108864
BLOCKZILLA_RAW_MAX_RECORD_BYTES=134217728
BLOCKZILLA_RAW_MIN_FREE_BYTES=402653184
BLOCKZILLA_RAW_GENERATION_BACKLOG_WARN_COUNT=2
BLOCKZILLA_RAW_GENERATION_UPLOAD_RETRY_SECS=60
# Upload every sealed generation to R2 promptly. R2 is an additional durable
# copy, not a deletion receipt. Keep every local generation until a verified
# signed Blockzilla durable-raw ACK exists; until that protocol is implemented,
# disk pressure pauses capture at the hard floor instead of deleting data.
BLOCKZILLA_RAW_B2_SPILL_START_PERCENT=25
BLOCKZILLA_RAW_B2_SPILL_RECOVERY_PERCENT=35
BLOCKZILLA_RAW_REPLAY_RESUME_HEADROOM_SLOTS=100
BLOCKZILLA_RAW_CACHE_RECEIPT_DIR=/data/grpc-cache/receipts
BLOCKZILLA_RAW_MEMORY_LIMIT=768m
BLOCKZILLA_RAW_MEMORY_RESERVATION=128m
BLOCKZILLA_RAW_VOLUME_NAME=blockzilla-live-raw-data-external
BLOCKZILLA_RAW_VOLUME_MARKER=/data/.blockzilla-raw-volume
BLOCKZILLA_RAW_REQUIRE_COMPLETE_POH=true
BLOCKZILLA_RAW_IDLE_TIMEOUT_SECS=180

# Hetzner is the sole paid Yellowstone consumer. Cloudflare R2 stores immutable
# committed generations beneath a recorder-specific prefix; Blockzilla and
# other consumers must use the Hetzner relay instead of opening another Triton
# subscription.
BLOCKZILLA_RAW_OBJECT_STORE=r2
BLOCKZILLA_RAW_OBJECT_STORE_CREDENTIALS_FILE=/run/secrets/r2_credentials
BLOCKZILLA_RAW_OBJECT_STORE_REMOTE_PREFIX=live-grpc-backup/v1
BLOCKZILLA_R2_CREDENTIALS_HOST_FILE=../files/cloudflare-r2.env

# These thresholds count only this recorder's validated committed receipt
# chain in the dedicated `blockzilla-live-grpc` R2 bucket. They are advisory
# until the whole-generation retention worker is enabled.
BLOCKZILLA_R2_USAGE_ALERT_ENABLED=true
BLOCKZILLA_R2_USAGE_WARNING_BYTES=800000000000
BLOCKZILLA_R2_USAGE_CRITICAL_BYTES=950000000000
BLOCKZILLA_R2_USAGE_RECOVERY_HYSTERESIS_BYTES=50000000000
BLOCKZILLA_R2_USAGE_CHECK_INTERVAL_SECS=3600
# Destructive remote retention is fail-closed until Blockzilla publishes signed,
# manifest-bound durable ACKs and the recorder verifies their contiguous chain.
BLOCKZILLA_R2_RETENTION_ENABLED=false
BLOCKZILLA_R2_RETENTION_TRIGGER_BYTES=950000000000
BLOCKZILLA_R2_RETENTION_TARGET_BYTES=900000000000
BLOCKZILLA_R2_RETENTION_MINIMUM_AGE_SECS=86400
BLOCKZILLA_R2_RETENTION_MINIMUM_RETAINED_GENERATIONS=2
BLOCKZILLA_R2_RETENTION_CHECK_INTERVAL_SECS=3600

# Backblaze values remain available for rollback. To use them, set the object
# store to `backblaze`, point the generic credentials file at
# `/run/secrets/backblaze_credentials`, and change the generic remote prefix.
BLOCKZILLA_B2_CREDENTIALS_HOST_FILE=../files/backblaze-blockzilla.env
BLOCKZILLA_B2_REMOTE_PREFIX=grpc-raw/v1
# Count every stored object version in every bucket in this B2 account, plus
# unfinished large-file parts. These are decimal-byte thresholds for the 10 GB
# free allowance; crossing them never stops upload or deletes remote data.
BLOCKZILLA_B2_USAGE_ALERT_ENABLED=true
BLOCKZILLA_B2_USAGE_ALLOWANCE_BYTES=10000000000
BLOCKZILLA_B2_USAGE_WARNING_BYTES=8000000000
BLOCKZILLA_B2_USAGE_CRITICAL_BYTES=9500000000
BLOCKZILLA_B2_USAGE_RECOVERY_HYSTERESIS_BYTES=500000000
BLOCKZILLA_B2_USAGE_CHECK_INTERVAL_SECS=3600
# Once critical has fired, reduce account-wide scans as version count grows.
BLOCKZILLA_B2_USAGE_OVER_LIMIT_CHECK_INTERVAL_SECS=21600
# Typed download, Class C, and storage caps use a slow retry loop.
BLOCKZILLA_B2_CAP_RETRY_SECS=3600

# Telegram alerts are enabled in this deployment. The bot token stays in a
# persistent Compose secret file; the chat/topic identifiers are not secrets.
BLOCKZILLA_TELEGRAM_ENABLED=true
BLOCKZILLA_TELEGRAM_BOT_TOKEN_HOST_FILE=../files/telegram-bot-token
BLOCKZILLA_TELEGRAM_CHAT_ID=
BLOCKZILLA_TELEGRAM_MESSAGE_THREAD_ID=
# Debounce only a quick reopen after recovery; active incidents do not repeat.
BLOCKZILLA_TELEGRAM_ALERT_COOLDOWN_SECS=900
BLOCKZILLA_RAW_DISK_WARN_FREE_BYTES=805306368
# Clear disk incidents only after another 128 MiB is available.
BLOCKZILLA_RAW_DISK_RECOVERY_HYSTERESIS_BYTES=134217728
BLOCKZILLA_RAW_MONITOR_INTERVAL_SECS=30

# Disabled until the authenticated primary/replica sync protocol writes a
# heartbeat file into the shared volume. A non-empty path enables this alert.
BLOCKZILLA_PRIMARY_SYNC_HEARTBEAT_FILE=
BLOCKZILLA_PRIMARY_SYNC_STALE_AFTER_SECS=600

# Conservative transport defaults. The server may answer without compression.
BLOCKZILLA_GRPC_ACCEPT_COMPRESSION=zstd
BLOCKZILLA_GRPC_HTTP2_ADAPTIVE_WINDOW=false
BLOCKZILLA_GRPC_HTTP2_KEEP_ALIVE_INTERVAL_SECS=30
BLOCKZILLA_GRPC_HTTP2_KEEP_ALIVE_TIMEOUT_SECS=10
BLOCKZILLA_GRPC_HTTP2_KEEP_ALIVE_WHILE_IDLE=false

# A fresh journal record is expected well inside this window during live ingest.
BLOCKZILLA_RAW_STALE_AFTER_SECS=180
BLOCKZILLA_RAW_STARTUP_GRACE_SECS=300
