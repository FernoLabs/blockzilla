# Cloudflare R2 S3 credentials for immutable live gRPC generation backup.
# Copy this file outside the repository and mount it read-only as the uploader
# credentials file. Never commit real values.
STORAGE_PROVIDER=r2
R2_S3_ENDPOINT=https://0123456789abcdef0123456789abcdef.r2.cloudflarestorage.com
R2_BUCKET=blockzilla-live-grpc
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key

# R2 is always signed with region `auto`; this line is optional because the
# uploader selects it automatically for explicit or inferred R2 endpoints.
R2_S3_REGION=auto

# Optional for temporary R2/S3 credentials. Long-lived R2 API tokens normally
# omit this value.
# AWS_SESSION_TOKEN=replace-with-temporary-session-token

# The supervisor appends its immutable generation path below this base prefix.
# This is documentation only; the uploader remains prefix-agnostic.
# BLOCKZILLA_R2_REMOTE_PREFIX=live-grpc-backup/v1
