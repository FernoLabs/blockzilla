{
  "schema_version": 2,
  "cluster_id": "solana-mainnet",
  "max_total_queue_bytes": 134217728,
  "max_total_queue_events": 4,
  "role": {
    "mode": "replica",
    "node_id": "backup-ingester-1",
    "upstream": {
      "endpoint": "https://192.168.1.45:9443",
      "tls": {
        "ca_file": "/etc/blockzilla/tls/primary-ca.crt",
        "client_certificate_file": "/etc/blockzilla/tls/replica.crt",
        "client_private_key_file": "/run/secrets/blockzilla-replica.key",
        "server_name": "nas-primary"
      },
      "auth": {
        "method": "mutual_tls"
      },
      "trusted_receipt_keys": [
