        "auth": {
          "method": "x_token",
          "credential": {
            "provider": "env",
            "variable": "BLOCKZILLA_BACKUP_GRPC_X_TOKEN"
          }
        },
        "tls": {
          "ca_file": "/etc/ssl/certs/ca-certificates.crt"
        },
        "reconnect": {
          "initial_delay_ms": 500,
          "max_delay_ms": 30000,
          "backoff_factor_milli": 2000,
          "jitter_percent": 20,
          "connect_timeout_ms": 5000,
          "heartbeat_interval_ms": 15000,
          "idle_timeout_ms": 60000,
          "max_attempts": null
